{
  "name": "@northernrough/hc3-mcp-server",
  "version": "4.5.0",
  "description": "Standalone Model Context Protocol server for Fibaro Home Center 3. 130+ tools with read-modify-write + post-write-verify guards on every mutating endpoint, HTTP transport, Z-Wave diagnostics, an audit family for cross-surface drift detection, and a 24-module per-domain architecture. Originally based on jangabrielsson/HC3_mcp.",
  "license": "MIT",
  "author": {
    "name": "northernRough",
    "email": "dev@cheetham.org",
    "url": "https://github.com/northernRough"
  },
  "contributors": [
    {
      "name": "Jan Gabrielsson",
      "url": "https://github.com/jangabrielsson"
    }
  ],
  "homepage": "https://github.com/northernRough/HC3_mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/northernRough/HC3_mcp.git"
  },
  "bugs": {
    "url": "https://github.com/northernRough/HC3_mcp/issues"
  },
  "keywords": [
    "fibaro",
    "hc3",
    "home-center-3",
    "smart-home",
    "mcp",
    "model-context-protocol",
    "home-automation",
    "iot",
    "claude",
    "claude-desktop",
    "cursor",
    "cline",
    "z-wave",
    "quickapp",
    "lua"
  ],
  "main": "./out/mcp/hc3-mcp-server.js",
  "bin": {
    "hc3-mcp-server": "./out/mcp/hc3-mcp-server.js"
  },
  "files": [
    "out/mcp/**/*.js",
    "out/mcp/**/*.d.ts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "DEPLOYMENT.md",
    "KNOWN_DEAD_ENDPOINTS.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepublishOnly": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && node scripts/test/unit-event-history-filters.mjs"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.3.0"
  }
}
