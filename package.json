{
  "name": "@northernrough/hc3-mcp-server",
  "version": "3.1.0",
  "description": "Standalone Model Context Protocol server for Fibaro Home Center 3. Actively maintained fork of jangabrielsson/HC3_mcp with verified write guardrails, bug fixes, and no local dependencies.",
  "license": "MIT",
  "author": {
    "name": "northernRough",
    "email": "dev@cheetham.org",
    "url": "https://github.com/northernRough"
  },
  "contributors": [
    {
      "name": "Jan Gabrielsson",
      "url": "https://github.com/jangabrielsson"
    }
  ],
  "homepage": "https://github.com/northernRough/HC3_mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/northernRough/HC3_mcp.git"
  },
  "bugs": {
    "url": "https://github.com/northernRough/HC3_mcp/issues"
  },
  "keywords": [
    "fibaro",
    "hc3",
    "home-center-3",
    "smart-home",
    "mcp",
    "model-context-protocol",
    "home-automation",
    "iot",
    "claude",
    "claude-desktop",
    "cursor",
    "cline",
    "z-wave",
    "quickapp",
    "lua"
  ],
  "main": "./out/mcp/hc3-mcp-server.js",
  "bin": {
    "hc3-mcp-server": "./out/mcp/hc3-mcp-server.js"
  },
  "files": [
    "out/mcp/**/*.js",
    "out/mcp/**/*.d.ts",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepublishOnly": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "echo 'no tests yet' && exit 0"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.3.0"
  }
