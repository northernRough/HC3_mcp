# Fibaro HC3 MCP Configuration
# Copy this file to ~/.env in your home directory and configure with your HC3 details

# Fibaro HC3 URL (IP address or hostname)
# Examples:
# HC3_URL=192.168.1.57
# HC3_URL=http://192.168.1.57
# HC3_URL=fibaro-hc3.local
HC3_URL=

# Fibaro HC3 Username
HC3_USER=

# Fibaro HC3 Password
HC3_PASSWORD=

# Optional: Port (default is 80)
# HC3_PORT=80
