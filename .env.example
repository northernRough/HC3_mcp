# Fibaro HC3 MCP Configuration
# Copy this file to .env and configure with your HC3 details (loaded automatically by dotenv)

# Fibaro HC3 host (IP address or hostname)
# Examples:
# FIBARO_HOST=192.168.1.57
# FIBARO_HOST=fibaro-hc3.local
FIBARO_HOST=

# Fibaro HC3 username (admin recommended for full surface)
FIBARO_USERNAME=

# Fibaro HC3 password
FIBARO_PASSWORD=

# Optional: HC3 port (default 80)
# FIBARO_PORT=80
